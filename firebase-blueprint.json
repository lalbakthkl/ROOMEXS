{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "A member of the room/mess.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the member" },
        "roomRentEnabled": { "type": "boolean", "description": "Whether this member pays room rent" },
        "messBillEnabled": { "type": "boolean", "description": "Whether this member participates in mess billing" },
        "totalDays": { "type": "number", "description": "Total days the member stayed in the mess" },
        "uid": { "type": "string", "description": "The UID of the user who created this member" }
      },
      "required": ["name", "roomRentEnabled", "messBillEnabled", "totalDays", "uid"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "A purchase made for the mess.",
      "type": "object",
      "properties": {
        "description": { "type": "string", "description": "What was bought" },
        "amount": { "type": "number", "description": "Cost of the purchase" },
        "date": { "type": "string", "format": "date-time", "description": "When the purchase was made" },
        "memberId": { "type": "string", "description": "ID of the member who made the purchase" },
        "uid": { "type": "string", "description": "The UID of the user who created this purchase" }
      },
      "required": ["description", "amount", "date", "memberId", "uid"]
    },
    "Summary": {
      "title": "Summary",
      "description": "Monthly summary of expenses.",
      "type": "object",
      "properties": {
        "month": { "type": "string", "description": "Month and year (e.g., March 2026)" },
        "totalRoomRent": { "type": "number", "description": "Total room rent for the month" },
        "totalPurchase": { "type": "number", "description": "Total purchase amount" },
        "totalDays": { "type": "number", "description": "Total days stayed by all members" },
        "perDayRate": { "type": "number", "description": "Calculated per day rate" },
        "memberDetails": { "type": "string", "description": "JSON string of member calculations" },
        "uid": { "type": "string", "description": "The UID of the user who created this summary" }
      },
      "required": ["month", "totalRoomRent", "totalPurchase", "totalDays", "perDayRate", "memberDetails", "uid"]
    },
    "User": {
      "title": "User",
      "description": "A user profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "User email" },
        "approved": { "type": "boolean", "description": "Whether the user is approved" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["email", "approved", "role", "createdAt"]
    },
    "Registration": {
      "title": "Registration",
      "description": "A pending registration request.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "User email" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the registration was requested" }
      },
      "required": ["email", "createdAt"]
    },
    "CleaningQueue": {
      "title": "Cleaning Queue",
      "description": "The current rotation queue for cleaning.",
      "type": "object",
      "properties": {
        "memberIds": { "type": "array", "items": { "type": "string" }, "description": "List of member IDs in rotation order" },
        "lastRotationDate": { "type": "string", "format": "date-time", "description": "When the last rotation occurred" },
        "uid": { "type": "string", "description": "The UID of the user who created this queue" }
      },
      "required": ["memberIds", "uid"]
    },
    "CleaningHistory": {
      "title": "Cleaning History",
      "description": "History of cleaning events.",
      "type": "object",
      "properties": {
        "memberId": { "type": "string", "description": "ID of the member who cleaned or skipped" },
        "memberName": { "type": "string", "description": "Name of the member" },
        "date": { "type": "string", "format": "date-time", "description": "When the event occurred" },
        "status": { "type": "string", "enum": ["completed", "skipped"], "description": "Status of the cleaning event" },
        "uid": { "type": "string", "description": "The UID of the user who created this history record" }
      },
      "required": ["memberId", "memberName", "date", "status", "uid"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of members"
    },
    "/purchases/{purchaseId}": {
      "schema": "Purchase",
      "description": "Collection of purchases"
    },
    "/summaries/{summaryId}": {
      "schema": "Summary",
      "description": "Collection of historical summaries"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/registrations/{regId}": {
      "schema": "Registration",
      "description": "Collection of pending registrations"
    },
    "/cleaning/queue": {
      "schema": "CleaningQueue",
      "description": "The singleton cleaning queue document"
    },
    "/cleaning_history/{historyId}": {
      "schema": "CleaningHistory",
      "description": "Collection of cleaning history records"
    }
  }
}
